{
  "name": "notefade",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:config": "node scripts/gen-wrangler-config.cjs",
    "worker:dev": "node scripts/gen-wrangler-config.cjs && wrangler dev worker/index.ts --port 8787",
    "worker:deploy": "node scripts/gen-wrangler-config.cjs && wrangler deploy worker/index.ts",
    "deploy": "yarn build && wrangler pages deploy dist/"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "happy-dom": "^17.4.0",
    "typescript": "^5.7.0",
    "vite": "~6.1.0",
    "vitest": "~2.1.0",
    "wrangler": "^3.109.0"
  }
}
