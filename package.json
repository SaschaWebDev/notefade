{
  "name": "notefade",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.14.0"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently --names vite,worker --prefix-colors blue,yellow \"yarn dev:vite\" \"yarn worker:dev\"",
    "dev:vite": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:config": "node scripts/gen-wrangler-config.cjs",
    "worker:dev": "node scripts/gen-wrangler-config.cjs && wrangler dev worker/index.ts --port 8686",
    "worker:deploy": "node scripts/gen-wrangler-config.cjs && wrangler deploy worker/index.ts --env production",
    "build:manifest": "node scripts/build-manifest.cjs",
    "build:prod": "tsc --noEmit && vite build && node scripts/inject-sri.cjs && node scripts/build-manifest.cjs",
    "build:docker": "docker build -f Dockerfile.build --output type=local,dest=./dist-verify .",
    "deploy": "yarn build && wrangler pages deploy dist/",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "qrcode-generator": "^2.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@playwright/test": "^1.50.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "happy-dom": "^17.4.0",
    "typescript": "^5.7.0",
    "vite": "~6.1.0",
    "vitest": "~2.1.0",
    "wrangler": "^3.109.0"
  }
}
